generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                Int      @id @default(autoincrement())
  nomeCompleto      String
  email             String   @unique
  senha             String
  perfil            String   @default("Membro") // Membro, Líder, Pastor, Administrador
  dataNascimento    DateTime?
  exibirAniversario Boolean  @default(true)
  batizado Boolean @default(false)
  estadoCivil       String?
  fotoUrl           String?  
  sexo              String // "Masculino", "Feminino"
  profissao         String?

  conteudos         Conteudo[]
  cursosCriados      Curso[]        @relation("CriadorCurso")
  historicoCursos    UsuarioCurso[]
  participacoesSalas UsuarioSala[]
  pedidosOracao     PedidoOracao[]
  // leiturasDiarias   LeituraDiaria[]
  gruposFamiliares  MembroFamilia[] @relation("MembroDoGrupo")
  convitesEnviados  MembroFamilia[] @relation("ConvitesEnviados")
  gruposCriados     GrupoFamiliar[]  @relation("CriadorGrupo")
  eventosCriados     Evento[]  @relation("EventosCriados")

  @@map("usuarios")
}

model Conteudo {
  id             Int       @id @default(autoincrement())
  usuarioId      Int
  tipo           String    // Estudo, Devocional, Aviso, Material, Apresentacao
  titulo         String
  texto          String?   // Texto principal (pode ser rich text)
  imagemUrl      String?   // URL da imagem
  videoUrl       String?   // URL do vídeo
  formato        String    // texto, imagem, vídeo, combinacao
  dataPublicacao DateTime  @default(now())
  principal      Boolean   @default(false)
  dataValidade   DateTime? // Usado para Avisos (opcional)

  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("conteudos")
}

model PedidoOracao {
  id              Int      @id @default(autoincrement())
  autorUsuarioId  Int
  descricaoPedido String
  dataEnvio       DateTime @default(now())
  visibilidade    String   @default("todos")

  autor           Usuario  @relation(fields: [autorUsuarioId], references: [id], onDelete: Cascade)

  @@map("pedidos_oracao")
}

model Curso {
  id                Int      @id @default(autoincrement())
  criadorUsuarioId  Int
  nome              String
  descricaoMaterial String?
  categoria         String   // "Homens", "Mulheres", "Casais", "Jovens", "Geral", etc.

  criador           Usuario  @relation("CriadorCurso", fields: [criadorUsuarioId], references: [id])
  salas             SalaCurso[]
  historicoUsuarios UsuarioCurso[]

  @@map("cursos")
}

model SalaCurso {
  id         Int      @id @default(autoincrement())
  cursoId    Int
  nomeSala   String
  dataInicio DateTime?
  dataFim    DateTime?
  status     String   @default("ativa")   // "ativa", "inativa", "concluída"

  curso      Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  participantes UsuarioSala[]

  @@map("salas_curso")
}

model UsuarioCurso {
  usuarioId  Int
  cursoId    Int
  dataAdicao DateTime @default(now())
  status     String   // "em andamento" | "concluído"

  usuario    Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  curso      Curso   @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, cursoId])
  @@map("usuarios_cursos")
}

model UsuarioSala {
  salaId        Int
  usuarioId     Int
  dataMatricula DateTime @default(now())
  status        String   @default("ativo")   // "ativo" | "cancelado_pelo_usuario" | "concluido" | "desistente"

  sala     SalaCurso @relation(fields: [salaId], references: [id], onDelete: Cascade)
  usuario  Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([salaId, usuarioId])
  @@map("usuarios_salas")
}

model GrupoFamiliar {
  id    Int     @id @default(autoincrement())
  nome  String?
  criadorUsuarioId Int  

  criador Usuario       @relation("CriadorGrupo", fields: [criadorUsuarioId], references: [id])
  membros MembroFamilia[]

  @@map("grupos_familiares")
}

model MembroFamilia {
  id              Int     @id @default(autoincrement())
  usuarioId       Int
  grupoFamiliarId Int
  parentesco      String? // "Pai", "Mãe", "Filho", "Cônjuge", "Tio", "Primo", etc.
  status          String  @default("pendente") // "pendente", "aceito", "recusado"
  convidadoPorId  Int

  usuario       Usuario       @relation("MembroDoGrupo", fields: [usuarioId], references: [id], onDelete: Cascade)
  grupoFamiliar GrupoFamiliar @relation(fields: [grupoFamiliarId], references: [id], onDelete: Cascade)
  convidadoPor  Usuario       @relation("ConvitesEnviados", fields: [convidadoPorId], references: [id])

  @@unique([usuarioId, grupoFamiliarId])
  @@map("membros_familia")
}


model Evento {
  id                 Int       @id @default(autoincrement())
  titulo             String
  descricao          String?
  local              String?
  dataInicio         DateTime
  dataFim            DateTime?
  tipo               String    @default("Outro") // "Culto", "Reunião", "Retiro", "Conferência", "Outro"
  cor                String?
  recorrencia        String    @default("nenhuma") // "nenhuma", "semanal", "mensal"
  diaSemana          Int?
  diaDoMes           Int?
  dataFimRecorrencia DateTime?
  criadorId          Int

  criador            Usuario   @relation("EventosCriados", fields: [criadorId], references: [id])

  @@map("eventos")
}

model TokenRevogado {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiraEm  DateTime
  criadoEm  DateTime @default(now())

  @@map("tokens_revogados")
}